{
  "name": "tinker-vue",
  "version": "0.1.467",
  "description": "secret",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "test": "echo skipping...",
    "cc": "prettier --check './src/**/*.{css,pcss,js,vue}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,vue}'",
    "spell": "cspell './**/*.{js,vue}'",
    "open": "open https://tinker-vue.vercel.app"
  },
  "dependencies": {
    "core-js": "3.49.0",
    "pinia": "3.0.4",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "autoprefixer": "10.5.2",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "only-allow": "1.2.2",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.513",
    "tailwindcss": "4.3.2",
    "vite": "8.1.4",
    "yoctocolors": "2.1.2"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "jest": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "rules": {},
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
