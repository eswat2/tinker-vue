{
  "name": "tinker-vue",
  "version": "0.1.455",
  "description": "secret",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "test": "echo skipping...",
    "cc": "prettier --check './src/**/*.{css,pcss,js,vue}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,vue}'",
    "spell": "cspell './**/*.{js,vue}'",
    "open": "open https://tinker-vue.vercel.app"
  },
  "dependencies": {
    "core-js": "3.49.0",
    "pinia": "3.0.4",
    "vue": "3.5.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "autoprefixer": "10.5.1",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.509",
    "tailwindcss": "4.3.1",
    "vite": "8.1.0",
    "yoctocolors": "2.1.2"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "jest": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "rules": {},
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
